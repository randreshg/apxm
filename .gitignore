# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/


# APXM Configuration
.apxm/*

# Build directories (CMake, etc.)
**/build/

# Python
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
.eggs/
.pytest_cache/

# macOS
.DS_Store

# Editor/IDE
*.swp
*.swo
*~
.vscode/
.idea/

# Clangd cache
.cache/

# APXM compiled artifacts
*.apxmobj


# Compiled workflow binaries (extensionless)
papers/**/workloads/**/workflow
papers/**/workloads/**/compile
papers/**/workloads/**/classification
papers/**/workloads/**/creative
papers/**/workloads/**/extraction
papers/**/workloads/**/reasoning
papers/**/workloads/**/parallel_research
papers/**/workloads/**/sequential_reasoning
papers/**/workloads/**/simple_chain
papers/**/workloads/**/workflow_n2
papers/**/workloads/**/workflow_n4
papers/**/workloads/**/workflow_n8
papers/**/workloads/**/03_empty_capability
papers/**/workloads/**/05_switch_empty_cases

# Python cache
.python-cache

# Coverage
.coverage
.coverage.*
htmlcov/

# Benchmark results and metrics
papers/**/metrics.json
papers/**/diagnostics.json
metrics.json

# Benchmark run results (generated, not committed)
papers/**/benchmarks/results/
!papers/**/benchmarks/results/.gitkeep

# Conda/mamba temp files
condaenv.*.requirements.txt
mamba*

# Build
.apxm

# Local machine-specific cargo config (contains local paths, do not commit)
# Copy .cargo/config.toml.example to .cargo/config.toml and fill in your paths
.cargo/config.toml

# Worktrees (managed by git worktree, not part of main tree)
.worktrees/

# Environment / secrets
.env
.env.*
*.key
*.pem
apxm.toml.local