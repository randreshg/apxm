// critic.ais — Critical Review Agent
//
// Receives a research plan from the Coordinator via /v1/receive,
// analyzes it for gaps, biases, counterarguments, and missing perspectives,
// then returns a structured critical review.
//
// Role: Adversarial reviewer — challenges assumptions, identifies blind spots,
// and ensures intellectual rigor in the final synthesis.
//
// Runs in PARALLEL with researcher.ais — both are dispatched simultaneously
// by the Coordinator. The APXM scheduler exploits this data-independence.
//
// Server setup:
//   APXM_SERVER_ADDR=127.0.0.1:18802 apxm-server

agent Critic {
    memory {
        session: STM
    }

    // Identify structural gaps and missing scope in the research plan.
    flow identify_gaps(research_plan: str) -> str {
        reason(
            prompt: "Analyze this research plan for gaps:\n\n" + research_plan + "\n\n"
                    + "Identify:\n"
                    + "1. Scope gaps — what important topics are not covered?\n"
                    + "2. Methodology gaps — what research approaches are missing?\n"
                    + "3. Perspective gaps — whose viewpoint is absent?\n\n"
                    + "Be specific and actionable. Each gap should suggest what to add.",
            budget_tokens: 1200,
            backend: "apxm"
        ) -> gaps

        return gaps
    }

    // Find potential biases and counterarguments.
    flow find_counterarguments(research_plan: str) -> str {
        reason(
            prompt: "For this research plan, identify:\n\n" + research_plan + "\n\n"
                    + "1. Confirmation bias risks — where might the framing bias findings?\n"
                    + "2. Strongest counterarguments to the likely conclusions\n"
                    + "3. Alternative interpretations of the same evidence\n"
                    + "4. Conflicting expert opinions in this domain\n\n"
                    + "Be rigorous. Steel-man opposing views.",
            budget_tokens: 1200,
            backend: "apxm"
        ) -> counterargs

        return counterargs
    }

    // Produce structured critical review combining gap analysis and counterarguments.
    flow produce_critique(gaps: str, counterargs: str, research_plan: str) -> str {
        ask(
            prompt: "Produce a structured critical review of this research plan.\n\n"
                    + "Research Plan:\n" + research_plan + "\n\n"
                    + "Gap Analysis:\n" + gaps + "\n\n"
                    + "Counterarguments:\n" + counterargs + "\n\n"
                    + "Format as:\n"
                    + "## Critical Assessment\n"
                    + "## Key Gaps (prioritized)\n"
                    + "## Strongest Counterarguments\n"
                    + "## Recommended Additions\n"
                    + "## Verdict: RIGOROUS / NEEDS_WORK / INSUFFICIENT",
            backend: "apxm"
        ) -> full_critique

        return full_critique
    }

    // Entry point: receives research_plan from Coordinator's COMMUNICATE call.
    // Runs concurrently with Researcher — no shared state needed.
    @entry flow critique(research_plan: str) -> str {
        // Run both analysis flows — APXM schedules them in parallel
        // since they have no data dependency between them
        identify_gaps(research_plan) -> gaps
        find_counterarguments(research_plan) -> counterargs

        // Combine into final structured critique
        produce_critique(gaps, counterargs, research_plan) -> full_critique

        return full_critique
    }
}
