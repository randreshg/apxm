// coordinator.ais — 3-Agent Collaborative Research Coordinator
//
// This is the flagship APXM demo: shows compilation, parallelism, HITL checkpoint,
// and cross-agent COMMUNICATE in a single runnable program.
//
// Architecture:
//   Coordinator dispatches research + critique in PARALLEL via COMMUNICATE,
//   then PAUSE for human review, then synthesizes a final report.
//
// Prerequisites:
//   - apxm-server running on port 18800 (coordinator)
//   - apxm-server running on port 18801 (researcher)
//   - apxm-server running on port 18802 (critic)
//   - Run: ./demo/run_demo.sh
//
// What Python frameworks cannot do:
//   ✗ LangGraph  — no binary compilation, no static analysis, sequential default
//   ✗ AutoGen    — no typed ISA, no binary distribution, no formal parallelism
//   ✗ CrewAI     — no compiler, no optimizer, no PAUSE/RESUME checkpoint
//   ✓ APXM       — compiled binary, verified before run, parallel, HITL, metrics

agent Coordinator {
    memory {
        session: STM
    }

    // Decompose the goal and plan the research approach.
    // Uses the on-premises backend — deep reasoning step.
    flow plan_research(goal: str) -> str {
        plan(
            prompt: "Decompose this research goal into exactly 3 concrete sub-questions. "
                    + "Format as a numbered list. Goal: " + goal,
            budget_tokens: 1000,
            backend: "apxm"
        ) -> research_plan

        return research_plan
    }

    // Dispatch to researcher agent via COMMUNICATE (HTTP).
    // The runtime looks up "researcher" in the agent registry
    // and POSTs the research_plan to http://localhost:18801/v1/receive.
    flow gather_research(research_plan: str) -> str {
        communicate(
            recipient: "researcher",
            protocol: "http",
            message: research_plan
        ) -> research_results

        return research_results
    }

    // Dispatch to critic agent via COMMUNICATE (HTTP).
    // Runs in PARALLEL with gather_research — KPN dataflow semantics
    // guarantee deterministic merge when both complete.
    flow gather_critique(research_plan: str) -> str {
        communicate(
            recipient: "critic",
            protocol: "http",
            message: research_plan
        ) -> critique

        return critique
    }

    // Final synthesis step — incorporates both findings and human notes.
    // The PAUSE checkpoint injects human_input from the checkpoint resume call.
    flow synthesize(research_results: str, critique: str, human_notes: str) -> str {
        reason(
            prompt: "Synthesize these findings into a comprehensive final report.\n\n"
                    + "=== Research Findings ===\n" + research_results + "\n\n"
                    + "=== Critical Review ===\n" + critique + "\n\n"
                    + "=== Human Reviewer Notes ===\n" + human_notes + "\n\n"
                    + "Produce a structured report: Executive Summary, Key Findings, "
                    + "Gaps Identified, Recommendations.",
            budget_tokens: 3000,
            backend: "apxm"
        ) -> final_report

        return final_report
    }

    // Main coordinator entry point.
    // Step 1: Plan → Step 2a+2b (parallel) → Step 3: human PAUSE → Step 4: synthesize
    @entry flow research(goal: str) -> str {
        // Step 1: Plan the research
        plan_research(goal) -> research_plan

        // Step 2a: Dispatch to researcher (triggers HTTP COMMUNICATE)
        gather_research(research_plan) -> research_results

        // Step 2b: Dispatch to critic (triggers HTTP COMMUNICATE, parallel with 2a)
        // APXM scheduler runs 2a and 2b concurrently — latency = max(researcher, critic)
        gather_critique(research_plan) -> critique

        // Step 3: Human-in-the-loop checkpoint
        // Execution pauses here; human reviews all_findings via checkpoint API
        pause(
            message: "Research and critique complete. Review findings before final synthesis.",
            display_data: "Research: " + research_results + "\n\nCritique: " + critique
        ) -> human_notes

        // Step 4: Synthesize final report incorporating human input
        synthesize(research_results, critique, human_notes) -> final_report

        return final_report
    }
}
