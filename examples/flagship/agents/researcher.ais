// researcher.ais — Deep Research Agent
//
// Receives a research plan from the Coordinator via /v1/receive,
// extracts key questions, conducts thorough research, stores findings in LTM,
// and returns evidence-backed answers.
//
// LLM strategy:
//   - Cheap model (on-premises backend, fast) for question extraction
//   - Powerful model (on-premises backend, high token budget) for deep research
//
// The store_fact() call persists findings in Long-Term Memory (LTM),
// so future sessions can recall this research without repeating LLM calls.
//
// Server setup:
//   APXM_SERVER_ADDR=127.0.0.1:18801 apxm-server

agent Researcher {
    memory {
        session: STM
        long_term: LTM
    }

    // Extract the concrete questions from the research plan.
    // Uses a low-temperature fast call — parsing task, not creative.
    flow extract_questions(research_plan: str) -> str {
        ask(
            prompt: "Extract the 3 numbered research questions from this plan. "
                    + "Output only the questions, one per line, no preamble.\n\n"
                    + research_plan,
            temperature: 0.1,
            backend: "apxm"
        ) -> questions

        return questions
    }

    // Conduct deep research on the extracted questions.
    // High token budget to allow thorough, evidence-backed answers.
    flow deep_research(questions: str) -> str {
        think(
            prompt: "Research each of these questions thoroughly:\n\n" + questions + "\n\n"
                    + "For each question:\n"
                    + "1. State the key facts with source attribution where possible\n"
                    + "2. Note any conflicting evidence or uncertainty\n"
                    + "3. Quantify claims where possible (numbers, dates, benchmarks)\n\n"
                    + "Be rigorous and factual. Flag speculation explicitly.",
            budget_tokens: 4000,
            backend: "apxm"
        ) -> research_results

        return research_results
    }

    // Store findings in LTM for future session recall.
    flow persist_findings(topic: str, findings: str) {
        store_memory(topic, findings)
    }

    // Entry point: receives research_plan from Coordinator's COMMUNICATE call.
    // Registered flow name must match what Coordinator sends to.
    @entry flow research(research_plan: str) -> str {
        // Step 1: Extract structured questions from the plan
        extract_questions(research_plan) -> questions

        // Step 2: Deep research — high token budget, factual focus
        deep_research(questions) -> research_results

        // Step 3: Persist findings in LTM (fire-and-forget style)
        persist_findings("collaborative_research_session", research_results)

        return research_results
    }
}
