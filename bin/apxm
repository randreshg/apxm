#!/bin/bash

# APXM CLI wrapper
# Auto-detects conda environment and sets up MLIR/LLVM paths.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APXM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PYTHON_CLI="${SCRIPT_DIR}/apxm_cli.py"

# ── Find the apxm conda environment ──────────────────────────────────────────

find_conda_prefix() {
    # 1. Already activated and correct
    if [[ -n "${CONDA_PREFIX:-}" ]]; then
        local env_name
        env_name="$(basename "$CONDA_PREFIX")"
        if [[ "$env_name" == "apxm" ]] || [[ -d "$CONDA_PREFIX/lib/cmake/mlir" ]]; then
            echo "$CONDA_PREFIX"
            return 0
        fi
    fi

    # 2. Query conda/mamba for the apxm environment
    local conda_cmd=""
    if command -v mamba >/dev/null 2>&1; then
        conda_cmd="mamba"
    elif command -v conda >/dev/null 2>&1; then
        conda_cmd="conda"
    fi

    if [[ -n "$conda_cmd" ]]; then
        local env_path
        env_path=$("$conda_cmd" info --envs 2>/dev/null | grep -E '^\s*apxm\s' | awk '{print $NF}' || true)
        if [[ -n "$env_path" ]] && [[ -d "$env_path" ]]; then
            echo "$env_path"
            return 0
        fi
        # Try JSON format
        env_path=$("$conda_cmd" info --envs --json 2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
for p in data.get('envs', []):
    if p.endswith('/apxm'):
        print(p)
        break
" 2>/dev/null || true)
        if [[ -n "$env_path" ]] && [[ -d "$env_path" ]]; then
            echo "$env_path"
            return 0
        fi
    fi

    # 3. Common locations
    for candidate in \
        "$HOME/miniforge3/envs/apxm" \
        "$HOME/mambaforge/envs/apxm" \
        "$HOME/miniconda3/envs/apxm" \
        "$HOME/anaconda3/envs/apxm" \
        "/opt/conda/envs/apxm"; do
        if [[ -d "$candidate/lib/cmake/mlir" ]]; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

# ── Find a suitable Python interpreter ────────────────────────────────────────

has_required_deps() {
    "$1" -c "import typer, rich" 2>/dev/null
}

find_python() {
    local conda_prefix="${1:-}"
    local candidates=()

    # Prefer the conda env's Python
    if [[ -n "$conda_prefix" ]] && [[ -x "$conda_prefix/bin/python3" ]]; then
        candidates+=("$conda_prefix/bin/python3")
    fi

    # Virtual env
    if [[ -n "${VIRTUAL_ENV:-}" ]] && [[ -x "${VIRTUAL_ENV}/bin/python3" ]]; then
        candidates+=("${VIRTUAL_ENV}/bin/python3")
    fi

    # Local .venv
    if [[ -x "${SCRIPT_DIR}/.venv/bin/python3" ]]; then
        candidates+=("${SCRIPT_DIR}/.venv/bin/python3")
    fi

    # System Python
    if command -v python3 >/dev/null 2>&1; then
        candidates+=("$(command -v python3)")
    fi

    for candidate in "${candidates[@]}"; do
        if [[ -x "$candidate" ]] && has_required_deps "$candidate"; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

# ── Setup environment ─────────────────────────────────────────────────────────

setup_env() {
    local conda_prefix="$1"

    export CONDA_PREFIX="$conda_prefix"
    export MLIR_DIR="$conda_prefix/lib/cmake/mlir"
    export LLVM_DIR="$conda_prefix/lib/cmake/llvm"

    # Library paths for runtime linking
    local lib_paths="$conda_prefix/lib"
    if [[ -d "$APXM_DIR/target/release/lib" ]]; then
        lib_paths="$APXM_DIR/target/release/lib:$lib_paths"
    fi
    if [[ -d "$APXM_DIR/target/release" ]]; then
        lib_paths="$APXM_DIR/target/release:$lib_paths"
    fi

    case "$(uname -s)" in
        Darwin)
            export DYLD_LIBRARY_PATH="${lib_paths}${DYLD_LIBRARY_PATH:+:$DYLD_LIBRARY_PATH}"
            ;;
        *)
            export LD_LIBRARY_PATH="${lib_paths}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
            ;;
    esac
}

# ── Main ──────────────────────────────────────────────────────────────────────

if [[ ! -f "$PYTHON_CLI" ]]; then
    echo "Error: apxm_cli.py not found at $PYTHON_CLI"
    exit 1
fi

CONDA_PREFIX_FOUND=""
if CONDA_PREFIX_FOUND="$(find_conda_prefix)"; then
    setup_env "$CONDA_PREFIX_FOUND"
fi

PYTHON=""
if ! PYTHON="$(find_python "$CONDA_PREFIX_FOUND")"; then
    echo "Error: No Python interpreter with typer and rich found."
    echo "Install with: conda activate apxm  (or pip install typer rich)"
    exit 1
fi

exec "$PYTHON" "$PYTHON_CLI" "$@"
